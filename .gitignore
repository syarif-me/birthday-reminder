## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# VS Code settings and launch configs
.vscode/
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# Compiled Code Library
*.dll
*.exe
*.pdb
*.pdbx
*.dll.config
*.exe.config

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml

# Output of MSBuild
*.bld
*.out

# Saved properties for project rebuilds
*.rebuild

# Rider / IntelliJ IDEs
.idea/
*.sln.iml

# dotnet-cli / user secrets
secrets.json

# Local/Development environment settings (keep template/dev appsettings but ignore custom local changes if preferred)
# appsettings.local.json

# OS-specific files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
